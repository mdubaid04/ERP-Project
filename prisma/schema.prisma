// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// In prisma all fields are not nullable by default

enum Role {
  ADMIN
  MANAGER
  TEAM_LEADER
  EMPLOYEE
}

enum Gender {
  MALE
  FEMALE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
  UNPAID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum UpdateField {
  PHONENO
  EMAIL
}

// Employee Model
model Employee {
  empId              Int              @id @default(autoincrement())
  firstName          String
  lastName           String
  email              String           @unique
  profilePic         String?
  profilePicPublicId String?
  phoneNo            String           @unique
  dateOfBirth        DateTime?
  password           String
  role               Role
  gender             Gender?
  address            String?
  pinCode            String?
  city               String?
  state              String?
  joiningDate        DateTime?
  isActive           Boolean?
  departmentId       Int?
  department         Department?      @relation(fields: [departmentId], references: [deptId])
  managedDept        Department?      @relation("DeptManager")
  qualification      Qualification[]
  payroll            Payroll[]
  employeeleaves     Leave[]          @relation("EmployeeLeaves")
  reviewedLeaves     Leave[]          @relation("ReviewerLeaves")
  attendance         Attendance[]
  payrollHistory     PayrollHistory[] @relation("employeePayroll")
  payrollChangedBy   PayrollHistory[] @relation("changedByPayroll")
  assignedTasks      Task[]           @relation("assignedTasks")
  assignedByTasks    Task[]           @relation("assignedByTasks")
  updateRequests     UpdateRequest[]  @relation("EmployeeRequests")
  reviewedRequests   UpdateRequest[]  @relation("ReviewerRequests")
  totalLeaves        Int              @default(20)
  remainingLeaves    Int              @default(20)
  otp                String?
  otpExpiry          DateTime?
  refreshToken       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

// Qualification Model
model Qualification {
  qualId      Int      @id @default(autoincrement())
  empId       Int
  employee    Employee @relation(fields: [empId], references: [empId])
  degree      String
  university  String
  passingYear Int
  grade       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Department Model
model Department {
  deptId    Int        @id @default(autoincrement())
  name      String
  managerId Int?       @unique
  manager   Employee?  @relation("DeptManager", fields: [managerId], references: [empId])
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Payroll Model
model Payroll {
  payrollId Int      @id @default(autoincrement())
  empId     Int
  employee  Employee @relation(fields: [empId], references: [empId])
  issueDate DateTime
  salary    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empId, issueDate])
}

// Leave Model
model Leave {
  leaveId      Int           @id @default(autoincrement())
  empId        Int
  employee     Employee      @relation("EmployeeLeaves", fields: [empId], references: [empId])
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       RequestStatus @default(PENDING)
  reviewedBy   Int?
  reviewer     Employee?     @relation("ReviewerLeaves", fields: [reviewedBy], references: [empId])
  reviewerRole Role?
  reviewedAt   DateTime?
  leaveType    LeaveType
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Attendance Model
model Attendance {
  attendanceId Int              @id @default(autoincrement())
  empId        Int
  employee     Employee         @relation(fields: [empId], references: [empId])
  date         DateTime
  status       AttendanceStatus
  checkIn      DateTime
  checkOut     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

//Payroll History Model
model PayrollHistory {
  payrollHistoryId Int      @id @default(autoincrement())
  empId            Int
  employee         Employee @relation("employeePayroll", fields: [empId], references: [empId])
  oldSalary        Int
  newSalary        Int
  reason           String
  changeDate       DateTime
  changedById      Int
  changedBy        Employee @relation("changedByPayroll", fields: [changedById], references: [empId])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Task {
  taskId       Int        @id @default(autoincrement())
  taskName     String
  description  String
  issueDate    DateTime
  submitDate   DateTime
  dueDate      DateTime
  status       TaskStatus @default(PENDING)
  assignedToId Int
  assignedTo   Employee   @relation("assignedTasks", fields: [assignedToId], references: [empId])
  assignedById Int
  assignedBy   Employee   @relation("assignedByTasks", fields: [assignedById], references: [empId])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model UpdateRequest {
  requestId     Int           @id @default(autoincrement())
  empId         Int
  employee      Employee      @relation("EmployeeRequests", fields: [empId], references: [empId])
  fieldName     UpdateField
  oldValue      String
  newValue      String
  status        RequestStatus @default(PENDING)
  reviewedBy    Int?
  reviewer      Employee?     @relation("ReviewerRequests", fields: [reviewedBy], references: [empId])
  reviewerRole  Role?
  requestReason String?
  rejectReason  String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
